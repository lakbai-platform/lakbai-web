// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id             String         @id
  email          String         @unique
  name           String?
  avatarUrl      String?

  reviews        POIReview[]
  vouches        POIVouch[]
  favorites      POIFavorite[]
  journeys       Journey[]

  createdAt      DateTime       @default(now())
}

model POI {
  id               String         @id @default(cuid())
  name             String
  description      String         @db.Text
  latitude         Float          
  longitude        Float          
  vouchCount       Int            @default(0) 
  primaryTagId     String?
  primaryTag       POITag?        @relation("POIPrimaryTag", fields: [primaryTagId], references: [id], onDelete: SetNull)
  
  // Relations
  tags             POITag[]       @relation("POITags") // <--- Many-to-many relation for tags/themes
  address          POIAddress?
  galleries        POIGallery[]
  operatingHours   OperatingHours[]
  reviews          POIReview[]
  vouches          POIVouch[]
  favorites        POIFavorite[]
  itineraryItems   ItineraryItem[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([primaryTagId])
}

model POIAddress {
  id                 String    @id @default(cuid())
  poiId              String    @unique
  poi                POI       @relation(fields: [poiId], references: [id], onDelete: Cascade)

  // Single flexible address form for subdivision and rural/informal entries.
  // All fields are optional so admins can still review and complete partial submissions.
  blockLotNumber     String?
  houseNumber        String?
  purok              String?
  street             String?
  subdivisionName    String?
  barangay           String?
  cityMunicipality   String?
  province           String?
  postalCode         String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model POITagCluster {
  id          String   @id // e.g. 'FOOD', 'ATTRACTIONS'
  name        String   @unique // display label
  iconName    String   // e.g. 'Utensils', 'Landmark'

  tags        POITag[]

  createdAt   DateTime @default(now())
}

model POITag {
  id          String   @id // e.g., "Park", "Restaurant", "Hotel"
  name        String   @unique
  iconName    String?  // user suggested icon, e.g., 'Coffee'
  
  clusterId   String?
  cluster     POITagCluster? @relation(fields: [clusterId], references: [id])
  
  pois        POI[]    @relation("POITags") // <--- Many-to-many relation back to POI
  primaryForPOIs POI[] @relation("POIPrimaryTag")
}

model POIGallery {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poiId     String
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  imageUrl  String   

  createdAt DateTime @default(now())
}

model OperatingHours {
  id        String   @id @default(cuid())
  poiId     String
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  dayOfWeek Int      // 0 (Sun) to 6 (Sat)
  openTime  String?  // Format: "HH:mm" (e.g., "08:00")
  closeTime String?  // Format: "HH:mm" (e.g., "22:00")
  isClosed  Boolean  @default(false)
  is24Hours Boolean  @default(false)

  @@unique([poiId, dayOfWeek])
}

model POIReview {

  id        String   @id @default(cuid())
  poiId     String
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      
  content   String   @db.Text

  history   POIReviewHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model POIReviewHistory {
  id               String    @id @default(cuid())
  reviewId         String
  review           POIReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  
  previousContent  String    @db.Text
  previousRating   Int
  
  changedAt        DateTime  @default(now())
}

model POIVouch {
  id        String   @id @default(cuid())
  poiId     String
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([poiId, userId]) 
}

model POIFavorite {
  id        String   @id @default(cuid())
  poiId     String
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([poiId, userId]) 
}

model Journey {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?        @db.Text
  destination     String?
  startDate       DateTime?
  endDate         DateTime?
  isFlexibleDates Boolean        @default(false)
  companions      String?        
  preferences     String?        @db.Text
  budget          Int?
  
  chats           Chat[]
  itineraryItems  ItineraryItem[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Chat {
  id              String         @id @default(cuid())
  journeyId       String?
  journey         Journey?       @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  title           String
  
  messages        Message[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Message {
  id              String         @id @default(cuid())
  chatId          String
  chat            Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role            String         // "user" or "ai"
  content         String         @db.Text
  
  createdAt       DateTime       @default(now())
}

model ItineraryItem {
  id              String         @id @default(cuid())
  journeyId       String
  journey         Journey        @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  poiId           String
  poi             POI            @relation(fields: [poiId], references: [id], onDelete: Cascade)
  dayNumber       Int            
  orderIndex      Int            
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@unique([journeyId, poiId, dayNumber]) 
}
